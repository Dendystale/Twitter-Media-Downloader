{
  "manifest_version": 3,
  "name": "Twitter Video Downloader",
  "version": "1.0",
  "description": "Download any video from X (Twitter) directly to your Mac.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "nativeMessaging",
    "activeTab"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["html2canvas.min.js", "content.js"],
      "css": ["content.css"]
    }
  ]
}
